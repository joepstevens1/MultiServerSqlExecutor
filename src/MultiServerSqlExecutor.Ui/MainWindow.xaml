<Window x:Class="MultiServerSqlExecutor.Ui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:local="clr-namespace:MultiServerSqlExecutor.Ui"
        mc:Ignorable="d"
        Title="Multi-Server SQL Executor" Height="600" Width="900">
    <Window.Resources>
        <Style x:Key="RightSidebarExpanderStyle" TargetType="Expander">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Border BorderBrush="#FFD5D5D5" BorderThickness="1" Background="#FFF9F9F9">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="28" />
                                </Grid.ColumnDefinitions>

                                <Border x:Name="ExpandSite" Grid.Column="0" Padding="8">
                                    <ContentPresenter />
                                </Border>

                                <ToggleButton x:Name="HeaderSite"
                                              Grid.Column="1"
                                              IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                              BorderThickness="1,0,0,0"
                                              BorderBrush="#FFD5D5D5"
                                              Background="#FFECECEC"
                                              ToolTip="Show/hide selected databases">
                                    <TextBlock Text="{TemplateBinding Header}"
                                               FontWeight="SemiBold"
                                               Foreground="#FF333333">
                                        <TextBlock.LayoutTransform>
                                            <RotateTransform Angle="-90" />
                                        </TextBlock.LayoutTransform>
                                    </TextBlock>
                                </ToggleButton>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Window.CommandBindings>
        <CommandBinding Command="{x:Static local:MainWindow.RunCommand}" Executed="OnRun" />
    </Window.CommandBindings>
    <DockPanel>
        <!-- Menu bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Servers..." Click="OnOpenServers" />
                <MenuItem Header="_Groups..." Click="OnOpenGroups" />
                <Separator />
                <MenuItem x:Name="MenuSave" Header="_Save Combined CSV" Click="OnSaveCombined" />
                <Separator />
                <MenuItem Header="E_xit" Click="OnExit" />
            </MenuItem>
            <MenuItem x:Name="MenuGroupFilter" Header="Group _Filter" SubmenuOpened="OnGroupFilterMenuOpened">
                <MenuItem Header="_Refresh" Click="OnRefreshGroups" />
                <MenuItem Header="_Clear" Click="OnClearGroupSelection" />
                <Separator />
            </MenuItem>
            <MenuItem Header="_Run">
                <MenuItem x:Name="MenuRun" Header="_Run Query" Command="{x:Static local:MainWindow.RunCommand}" />
            </MenuItem>
        </Menu>
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="Elapsed:" />
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock x:Name="TxtElapsed" Text="00:00:00" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="Total:" />
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock x:Name="TxtTotalServers" Text="0" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="Waiting:" />
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock x:Name="TxtPendingServers" Text="0" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="Completed:" />
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock x:Name="TxtCompletedServers" Text="0" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="Selected:" />
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock x:Name="TxtSelectedServers" Text="0" />
            </StatusBarItem>
        </StatusBar>

        <!-- Main content area with resizable query/results and right status sidebar -->
        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="MainContentColumn" Width="*" />
                <ColumnDefinition x:Name="SidebarSplitterColumn" Width="6" />
                <ColumnDefinition x:Name="SidebarColumn" Width="280" MinWidth="28" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="5" />
                    <RowDefinition Height="2*" />
                </Grid.RowDefinitions>

                <!-- Query editor -->
                <GroupBox Header="SQL Query" Grid.Row="0" Margin="0,0,10,0">
                    <avalonedit:TextEditor x:Name="QueryEditor" ShowLineNumbers="True" FontFamily="Consolas" FontSize="14" SyntaxHighlighting="SQL"/>
                </GroupBox>

                <!-- Splitter with horizontal handle -->
                <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" VerticalAlignment="Center" Background="#FFC8C8C8" Margin="0,0,10,0" />

                <!-- Results -->
                <GroupBox Header="Results" Grid.Row="2" Margin="0,0,10,0">
                    <DataGrid x:Name="ResultsGrid" AutoGenerateColumns="True" IsReadOnly="True" />
                </GroupBox>
            </Grid>

            <GridSplitter x:Name="SidebarSplitter"
                          Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="#FFD0D0D0"
                          ShowsPreview="True"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext" />

            <Expander x:Name="DatabaseSidebar"
                      Grid.Column="2"
                      Style="{StaticResource RightSidebarExpanderStyle}"
                      Header="Selected Databases"
                      Expanded="OnDatabaseSidebarExpanded"
                      Collapsed="OnDatabaseSidebarCollapsed"
                      IsExpanded="True"
                      ExpandDirection="Left">
                <ListBox x:Name="DatabaseStatusList"
                         BorderThickness="0"
                         Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,3,0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{Binding DatabaseName}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"
                                               HorizontalAlignment="Left"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding DisplayName}" />

                                    <Border Grid.Column="1"
                                            Width="18"
                                            Height="18"
                                            CornerRadius="9"
                                            Background="{Binding StatusBrush}"
                                            ToolTip="{Binding StatusTooltip}">
                                        <TextBlock Text="{Binding StatusGlyph}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="10"
                                                   Foreground="White"
                                                   FontWeight="Bold" />
                                    </Border>
                                </Grid>

                                <Separator Grid.Row="1" Margin="0,3,0,0" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Expander>
        </Grid>
    </DockPanel>
</Window>
