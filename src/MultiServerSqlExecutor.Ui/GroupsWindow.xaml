<Window x:Class="MultiServerSqlExecutor.Ui.GroupsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manage Groups" Height="500" Width="860" MinWidth="700" MinHeight="420" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <GroupBox Grid.Column="0" Header="Groups" Margin="0,0,10,0">
            <DockPanel Margin="8">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBox x:Name="TxtGroupName" MinWidth="180" Margin="0,0,8,0" VerticalContentAlignment="Center" />
                    <Button Content="Add Group" Click="OnAddGroup" MinWidth="100" Margin="0,0,8,0" />
                    <Button Content="Remove Group" Click="OnRemoveGroup" MinWidth="110" />
                </StackPanel>
                <ListBox x:Name="GroupsList" SelectionChanged="OnGroupSelectionChanged" />
            </DockPanel>
        </GroupBox>

        <GroupBox Grid.Column="1" Header="Servers In Selected Group">
            <DockPanel Margin="8">
                <TextBlock x:Name="LblSelectedGroup" DockPanel.Dock="Top" Margin="0,0,0,8" FontWeight="SemiBold" />
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ServersItems">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Name}" IsChecked="{Binding IsInGroup, Mode=TwoWay}" Margin="0,2,0,2" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </GroupBox>

        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Save Membership" Click="OnSaveMembership" MinWidth="110" Margin="0,0,8,0" />
            <Button Content="Close" Click="OnClose" MinWidth="80" />
        </StackPanel>
    </Grid>
</Window>
